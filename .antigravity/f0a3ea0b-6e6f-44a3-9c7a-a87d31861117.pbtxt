der border-slate-200 text-slate-500 rounded-2xl p-4 text-xs flex items-center gap-2 max-w-sm shadow-2xs\">\n                <div className=\"flex gap-1 animate-pulse\">\n                  <span className=\"w-2 h-2 rounded-full bg-slate-400\"></span>\n                  <span className=\"w-2 h-2 rounded-full bg-slate-400\"></span>\n                  <span className=\"w-2 h-2 rounded-full bg-slate-400\"></span>\n                </div>\n                <span className=\"font-medium text-slate-600\">Super Agent processing prompts...</span>\n              </div>\n            </div>\n          )}"
