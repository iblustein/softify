  file_change {
    absolute_path_uri: "file:///src/components/AuditLogViewer.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { \n  Activity, \n  Search, \n  User, \n  Cpu, \n  Terminal, \n  Database,\n  Filter,\n  Check,\n  ChevronDown,\n  ChevronUp,\n  Clock,\n  Code\n} from \'lucide-react\';\nimport { AuditLog } from \'../types\';\n\ninterface AuditLogViewerProps {\n  logs: AuditLog[];\n}\n\nexport default function AuditLogViewer({ logs }: AuditLogViewerProps) {\n  const [searchTerm, setSearchTerm] = useState(\"\");\n  const [selectedInitiator, setSelectedInitiator] = useState<string>(\"ALL\");\n  const [expandedLogId, setExpandedLogId] = useState<string | null>(null);\n\n  const UNIQUE_INITIATORS = Array.from(new Set(logs.map(l => l.initiator)));\n\n  // Filter logic\n  const filteredLogs = logs.filter(log => {\n    const matchesSearch = log.description.toLowerCase().includes(searchTerm.toLowerCase()) || \n                          log.event.toLowerCase().includes(searchTerm.toLowerCase()) ||\n                          log.id.toLowerCase().includes(searchTerm.toLowerCase());\n    const matchesInitiator = selectedInitiator === \'ALL\' || log.initiator === selectedInitiator;\n    return matchesSearch && matchesInitiator;\n  });\n\n  const toggleExpand = (id: string) => {\n    setExpandedLogId(prev => prev === id ? null : id);\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <div className=\"border-b border-gray-100 pb-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4\">\n        <div>\n          <h2 className=\"text-base font-semibold text-gray-900 tracking-tight flex items-center gap-2\">\n            <Activity className=\"w-5 h-5 text-indigo-600\" />\n            Control Center Audit Log Trail\n          </h2>\n          <p className=\"text-xs text-gray-500 mt-1\">\n            Standard merchant telemetry logs. Every routing action, tool lookup, and state override is indexed here with complete microsecond precision.\n          </p>\n        </div>\n      </div>\n\n      {/* Filter bar */}\n      <div className=\"bg-white p-4 rounded-xl border border-gray-150 flex flex-col md:flex-row gap-3 items-stretch shadow-3xs text-xs\">\n        {/* Search input */}\n        <div className=\"flex-1 relative flex items-center\">\n          <span className=\"absolute left-3 text-gray-450 pointer-events-none\">\n            <Search className=\"w-4 h-4\" />\n          </span>\n          <input\n            type=\"text\"\n            value={searchTerm}\n            onChange={(e) => setSearchTerm(e.target.value)}\n            placeholder=\"Search logs by keyword, action ID, or event key...\"\n            className=\"w-full pl-9 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 text-xs text-gray-900 bg-white shadow-3xs\"\n          />\n        </div>\n\n        {/* Initiator dropdown filter */}\n        <div className=\"flex items-center gap-2 min-w-[200px]\">\n          <span className=\"text-gray-400 shrink-0 font-semibold flex items-center gap-1\">\n            <Filter className=\"w-3.5 h-3.5\" />\n            Filter Initiator:\n          </span>\n          <select\n            value={selectedInitiator}\n            onChange={(e) => setSelectedInitiator(e.target.value)}\n            className=\"w-full px-2.5 py-1.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white\"\n          >\n            <option value=\"ALL\">All Event Threads</option>\n            {UNIQUE_INITIATORS.map((init) => (\n              <option key={init} value={init}>{init}</option>\n            ))}\n          </select>\n        </div>\n      </div>\n\n      {/* Logs stack view */}\n      <div className=\"bg-white rounded-xl border border-gray-150 shadow-xs overflow-hidden\">\n        {filteredLogs.length === 0 ? (\n          <div className=\"p-12 text-center text-gray-400 max-w-sm mx-auto\">\n            <Activity className=\"w-10 h-10 text-gray-200 mx-auto mb-2\" style={{ animationDelay: \'100ms\' }} />\n            <p className=\"text-xs font-semibold\">No logs found matching filter</p>\n            <p className=\"text-3xs text-gray-500 mt-0.5\">Adjust filter terms or execute commands inside the Chat Terminal.</p>\n          </div>\n        ) : (\n          <div className=\"divide-y divide-gray-100\">\n            {filteredLogs.map((log) => {\n              const isExpanded = expandedLogId === log.id;\n              const isOwner = log.initiator === \'Shop Owner\';\n              const isOrchestrator = log.initiator === \'Super Agent Orchestrator\';\n\n              return (\n                <div key={log.id} className=\"transition hover:bg-gray-25/50\">\n                  <div \n                    onClick={() => toggleExpand(log.id)}\n                    className=\"p-4 flex flex-col sm:flex-row justify-between sm:items-center gap-3 cursor-pointer text-xs\"\n                  >\n                    <div className=\"flex items-start gap-3.5 flex-1 min-w-0\">\n                      {/* Identity visual Badge */}\n                      <div className={`w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs shrink-0 ${\n                        isOwner ? \'bg-indigo-50 text-indigo-700 border border-indigo-150\' : isOrchestrator ? \'bg-indigo-950 text-indigo-300 border border-indigo-900\' : \'bg-indigo-600 text-white\'\n                      }`}>\n                        {isOwner ? <User className=\"w-4 h-4\" /> : isOrchestrator ? <Terminal className=\"w-4 h-4\" /> : <Cpu className=\"w-4 h-4\" />}\n                      </div>\n\n                      <div className=\"min-w-0\">\n                        <div className=\"flex flex-wrap items-center gap-2\">\n                          <span className=\"font-bold text-gray-950\">{log.initiator}</span>\n                          <span className=\"text-gray-305 text-10px\">\342\200\242</span>\n                          <span className=\"font-mono text-3xs px-1.5 py-0.5 bg-gray-50 border border-gray-150 rounded text-gray-650 flex items-center leading-none\">\n                            {log.event}\n                          </span>\n                        </div>\n                        <p className=\"text-3xs text-gray-600 mt-1 lines-clamp-1 leading-relaxed\">\n                          {log.description}\n                        </p>\n                      </div>\n                    </div>\n\n                    <div className=\"flex sm:flex-col items-end gap-2 sm:gap-1.5 text-right shrink-0\">\n                      <span className=\"font-mono text-4xs text-gray-400\">{log.id}</span>\n                      <div className=\"flex items-center gap-1 text-4xs text-gray-500 font-mono\">\n                        <Clock className=\"w-3 h-3 text-gray-400\" />\n                        {new Date(log.timestamp).toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\', second: \'2-digit\' })}\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Expanded block containing formatted visual JSON */}\n                  {isExpanded && (\n                    <div className=\"p-4 bg-gray-50 border-t border-gray-100 flex flex-col gap-2.5\">\n                      <div className=\"flex items-center gap-1.5 text-4xs font-semibold uppercase tracking-wider text-gray-400\">\n                        <Code className=\"w-3.5 h-3.5 text-indigo-500\" />\n                        Raw Telemetry Payload ({log.id})\n                      </div>\n                      <div className=\"bg-gray-900 rounded-lg p-3 font-mono text-[9px] text-gray-100 overflow-auto max-h-48 border border-gray-800\">\n                        <pre>{JSON.stringify({\n                          id: log.id,\n                          timestamp: log.timestamp,\n                          initiator: log.initiator,\n                          event: log.event,\n                          description: log.description,\n                          metadata: log.metadata || {}\n                        }, null, 2)}</pre>\n                      </div>\n                    </div>\n                  )}\n                </div>\n              );\n            })}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n"
    }
    diff {
      unified_diff {
