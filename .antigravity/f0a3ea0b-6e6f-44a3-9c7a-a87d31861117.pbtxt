    replacement_chunks {
      target_content: "  return (\n    <div className=\"space-y-6\">\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-gray-100 pb-5 gap-4\">\n        <div>\n          <h2 className=\"text-base font-semibold text-gray-900 tracking-tight flex items-center gap-2\">\n            <FileCheck className=\"w-5 h-5 text-indigo-600\" />\n            Merchant Approval Safeguards Queue\n          </h2>\n          <p className=\"text-xs text-gray-500 mt-1\">\n            Gated security console. Review and authorize or discard write payloads proposed by active agent pipelines before live storefront commits.\n          </p>\n        </div>\n\n        {/* Tab Selection */}\n        <div className=\"flex border border-gray-200 rounded-lg p-0.5 bg-gray-50 max-w-sm shrink-0\">\n          <button\n            onClick={() => { setActiveTab(\'PENDING\'); setSelectedItem(pendingList[0] || null); }}\n            className={`px-3 py-1.5 text-3xs font-semibold rounded-md transition ${\n              activeTab === \'PENDING\' \n                ? \'bg-white text-indigo-950 shadow-2xs border border-gray-150\' \n                : \'text-gray-500 hover:text-gray-700\'\n            }`}\n          >\n            Pending Reviews ({pendingList.length})\n          </button>\n          <button\n            onClick={() => { setActiveTab(\'DECIDED\'); setSelectedItem(decidedList[0] || null); }}\n            className={`px-3 py-1.5 text-3xs font-semibold rounded-md transition ${\n              activeTab === \'DECIDED\' \n                ? \'bg-white text-indigo-950 shadow-2xs border border-gray-150\' \n                : \'text-gray-500 hover:text-gray-700\'\n            }`}\n          >\n            History Log ({decidedList.length})\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-5 gap-6 items-stretch\">\n        \n        {/* Left Side: Actions list */}\n        <div className=\"lg:col-span-2 space-y-2\">\n          {displayedList.length === 0 ? (\n            <div className=\"p-8 text-center border border-dashed border-gray-150 rounded-xl bg-gray-25 text-gray-400\">\n              <ShieldCheck className=\"w-8 h-8 text-indigo-300 mx-auto mb-2\" />\n              <p className=\"text-xs font-semibold\">No transactions found</p>\n              <p className=\"text-3xs text-gray-500 mt-0.5\">There are no overrides queued under this partition.</p>\n            </div>\n          ) : (\n            <div className=\"space-y-1.5 max-h-[500px] overflow-y-auto pr-1\">\n              {displayedList.map((item) => {\n                const isSelected = selectedItem?.id === item.id;\n                return (\n                  <div\n                    key={item.id}\n                    onClick={() => handleSelect(item)}\n                    className={`p-3.5 rounded-xl border text-xs cursor-pointer transition ${\n                      isSelected \n                        ? \'bg-indigo-25/40 border-indigo-400 ring-2 ring-indigo-400/5\' \n                        : \'bg-white border-gray-150 hover:border-gray-200\'\n                    }`}\n                  >\n                    <div className=\"flex justify-between items-start font-mono\">\n                      <span className=\"font-semibold text-gray-900\">{item.id}</span>\n                      <span className={`inline-flex items-center text-4xs font-mono px-1 rounded-sm border ${\n                        item.status === \'PENDING\' \n                          ? \'bg-amber-50 text-amber-700 border-amber-100\' \n                          : item.status === \'APPROVED\' \n                          ? \'bg-emerald-50 text-emerald-700 border-emerald-100\' \n                          : \'bg-red-50 text-red-700 border-red-100\'\n                      }`}>\n                        {item.status}\n                      </span>\n                    </div>\n\n                    <h3 className=\"font-semibold text-gray-800 mt-2 line-clamp-1\">\n                      {item.details.title}\n                    </h3>\n\n                    <div className=\"flex items-center justify-between border-t border-gray-100 mt-3 pt-2 text-4xs text-gray-400\">\n                      <span className=\"flex items-center gap-1 font-sans\">\n                        <User className=\"w-3 h-3 text-indigo-400\" />\n                        {item.agentName}\n                      </span>\n                      <span className=\"font-mono\">\n                        {new Date(item.timestamp).toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\' })}\n                      </span>\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          )}\n        </div>\n\n        {/* Right Side: Diff & Approval Actions */}\n        <div className=\"lg:col-span-3\">\n          {selectedItem ? (\n            <div className=\"bg-white rounded-xl border border-gray-150 p-5 flex flex-col justify-between h-full shadow-2xs\">\n              <div className=\"space-y-5\">\n                {/* Header Information */}\n                <div className=\"flex justify-between items-start border-b border-gray-100 pb-3\">\n                  <div>\n                    <span className=\"text-4xs text-gray-400 font-mono block\">Action ID: {selectedItem.id}</span>\n                    <h3 className=\"text-xs font-bold text-gray-900 mt-0.5\">{selectedItem.details.title}</h3>\n                  </div>\n                  \n                  <div className=\"flex items-center gap-1 text-3xs font-mono text-gray-500\">\n                    <Clock className=\"w-3.5 h-3.5\" />\n                    {new Date(selectedItem.timestamp).toLocaleDateString()} at {new Date(selectedItem.timestamp).toLocaleTimeString([], {hour: \'2-digit\', minute: \'2-digit\'})}\n                  </div>\n                </div>\n\n                {/* Proposed rationale */}\n                <div className=\"space-y-2\">\n                  <span className=\"block text-4xs font-semibold text-gray-400 uppercase tracking-widest leading-none flex items-center gap-1\">\n                    <AlertCircle className=\"w-3.5 h-3.5 text-indigo-505 text-indigo-500 shrink-0\" />\n                    Agent Justification & Change Summary\n                  </span>\n                  <p className=\"text-3xs text-gray-600 bg-indigo-25/30 border border-indigo-100/50 rounded-lg p-3 leading-relaxed italic\">\n                    \"{selectedItem.details.summary}\"\n                  </p>\n                </div>\n\n                {/* Side by side visual code diff comparison */}\n                <div className=\"space-y-2\">\n                  <span className=\"block text-4xs font-semibold text-gray-400 uppercase tracking-widest leading-none\">\n                    Write Action Comparison (Before vs After)\n                  </span>\n\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                    {/* Before parameters */}\n                    <div className=\"rounded-lg border border-red-100 flex flex-col overflow-hidden bg-red-25/30\">\n                      <span className=\"block px-2.5 py-1.5 text-4xs font-bold font-mono text-red-700 border-b border-red-100 bg-red-50 leading-none\">\n                        - CURRENT VALUE (DISCARDED)\n                      </span>\n                      <div className=\"p-3 font-mono text-3xs text-red-900 leading-relaxed overflow-x-auto max-h-48 whitespace-pre-wrap\">\n                        {selectedItem.details.before || \"// Property was previously blank or holds template values\"}\n                      </div>\n                    </div>\n\n                    {/* After parameters */}\n                    <div className=\"rounded-lg border border-emerald-100 flex flex-col overflow-hidden bg-emerald-25/30\">\n                      <span className=\"block px-2.5 py-1.5 text-4xs font-bold font-mono text-emerald-700 border-b border-emerald-100 bg-emerald-50 leading-none\">\n                        + DRAFTED REVISION (PROPOSED COMMIT)\n                      </span>\n                      <div className=\"p-3 font-mono text-3xs text-emerald-950 leading-relaxed overflow-x-auto max-h-48 whitespace-pre-wrap font-sans\">\n                        {selectedItem.details.after}\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              {/* Action Handlers */}\n              {selectedItem.status === \'PENDING\' ? (\n                <div className=\"pt-5 border-t border-gray-150 flex items-center justify-between gap-4 mt-5\">\n                  <span className=\"text-3xs text-gray-400 flex items-center gap-1 flex items-center gap-1\">\n                    <Eye className=\"w-4 h-4 text-indigo-500\" />\n                    Review parameters before accepting\n                  </span>\n                  \n                  <div className=\"flex gap-2.5 shrink-0\">\n                    <button\n                      onClick={() => handleAction(selectedItem.id, \'REJECT\')}\n                      disabled={isLoading}\n                      className=\"px-4 py-2 text-xs font-semibold text-red-650 bg-red-50 hover:bg-red-100 rounded-lg border border-red-100 shadow-2xs transition flex items-center gap-1 cursor-pointer animate-fade-in\"\n                    >\n                      <X className=\"w-3.5 h-3.5\" />\n                      Reject Payload\n                    </button>\n                    \n                    <button\n                      onClick={() => handleAction(selectedItem.id, \'APPROVE\')}\n                      disabled={isLoading}\n                      className=\"px-4 py-2 text-xs font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg shadow-2xs transition flex items-center gap-1 cursor-pointer shadow-xs animate-fade-in\"\n                    >\n                      <Check className=\"w-3.5 h-3.5\" />\n                      Approve & Execute Commit\n                    </button>\n                  </div>\n                </div>\n              ) : (\n                <div className=\"pt-4 border-t border-gray-100 mt-4 text-3xs text-gray-400 flex justify-between items-center bg-gray-50/50 p-3 rounded-lg border border-gray-150 font-mono\">\n                  <span>Authorized choice finalized on this payload.</span>\n                  <span className=\"font-semibold text-gray-600 uppercase\">\n                    Result: {selectedItem.status}\n                  </span>\n                </div>\n              )}\n            </div>\n          ) : (\n            <div className=\"h-full flex flex-col items-center justify-center text-center p-12 border border-dashed border-gray-150 rounded-xl max-w-sm mx-auto\">\n              <ShieldCheck className=\"w-10 h-10 text-gray-200 mb-2\" />\n              <p className=\"text-xs font-semibold text-gray-500\">No action selected</p>\n              <p className=\"text-3xs text-gray-400 mt-1\">Pick an item from the left tracking column to audit.</p>\n            </div>\n          )}\n        </div>\n\n      </div>\n    </div>"
      replacement_content: "  return (\n    <div className=\"space-y-6\">\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-slate-205 pb-5 gap-4\">\n        <div>\n          <h2 className=\"text-base font-bold text-slate-800 tracking-tight flex items-center gap-2 uppercase\">\n            <FileCheck className=\"w-5 h-5 text-indigo-650 text-indigo-600\" />\n            Merchant Approval Safeguards Queue\n          </h2>\n          <p className=\"text-xs text-slate-505 mt-1\">\n            Gated security console. Review and authorize or discard write payloads proposed by active agent pipelines before live storefront commits.\n          </p>\n        </div>\n\n        {/* Tab Selection */}\n        <div className=\"flex border border-slate-200 rounded-xl p-0.5 bg-slate-50/70 max-w-sm shrink-0 shadow-3xs\">\n          <button\n            onClick={() => { setActiveTab(\'PENDING\'); setSelectedItem(pendingList[0] || null); }}\n            className={`px-3 py-1.5 text-3xs font-bold rounded-lg transition-all ${\n              activeTab === \'PENDING\' \n                ? \'bg-white text-indigo-950 shadow-xs border border-slate-150\' \n                : \'text-slate-500 hover:text-slate-700\'\n            }`}\n          >\n            Pending Reviews ({pendingList.length})\n          </button>\n          <button\n            onClick={() => { setActiveTab(\'DECIDED\'); setSelectedItem(decidedList[0] || null); }}\n            className={`px-3 py-1.5 text-3xs font-bold rounded-lg transition-all ${\n              activeTab === \'DECIDED\' \n                ? \'bg-white text-indigo-950 shadow-xs border border-slate-150\' \n                : \'text-slate-500 hover:text-slate-700\'\n            }`}\n          >\n            History Log ({decidedList.length})\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-5 gap-6 items-stretch\">\n        \n        {/* Left Side: Actions list */}\n        <div className=\"lg:col-span-2 space-y-2\">\n          {displayedList.length === 0 ? (\n            <div className=\"p-8 text-center border border-dashed border-slate-200 rounded-2xl bg-slate-50/50 text-slate-400 font-sans\">\n              <ShieldCheck className=\"w-8 h-8 text-indigo-300 mx-auto mb-2\" />\n              <p className=\"text-xs font-bold text-slate-700\">No transactions found</p>\n              <p className=\"text-3xs text-slate-450 mt-0.5\">There are no overrides queued under this partition.</p>\n            </div>\n          ) : (\n            <div className=\"space-y-2 max-h-[500px] overflow-y-auto pr-1\">\n              {displayedList.map((item) => {\n                const isSelected = selectedItem?.id === item.id;\n                return (\n                  <div\n                    key={item.id}\n                    onClick={() => handleSelect(item)}\n                    className={`p-4 rounded-2xl border text-xs cursor-pointer transition-all ${\n                      isSelected \n                        ? \'bg-indigo-50/30 border-indigo-400 ring-2 ring-indigo-500/10 shadow-xs\' \n                        : \'bg-white border-slate-200 hover:border-slate-300\'\n                    }`}\n                  >\n                    <div className=\"flex justify-between items-start font-mono\">\n                      <span className=\"font-bold text-slate-800\">{item.id}</span>\n                      <span className={`inline-flex items-center text-4xs font-mono px-1.5 py-0.5 rounded font-bold uppercase ${\n                        item.status === \'PENDING\' \n                          ? \'bg-amber-50 text-amber-700 border border-amber-100 animate-pulse\' \n                          : item.status === \'APPROVED\' \n                          ? \'bg-emerald-50 text-emerald-700 border border-emerald-100\' \n                          : \'bg-red-50 text-red-700 border-red-100\'\n                      }`}>\n                        {item.status}\n                      </span>\n                    </div>\n\n                    <h3 className=\"font-bold text-slate-700 mt-2.5 line-clamp-1\">\n                      {item.details.title}\n                    </h3>\n\n                    <div className=\"flex items-center justify-between border-t border-slate-100 mt-3 pt-2 text-4xs text-slate-400\">\n                      <span className=\"flex items-center gap-1 font-sans font-bold\">\n                        <User className=\"w-3 h-3 text-indigo-400\" />\n                        {item.agentName}\n                      </span>\n                      <span className=\"font-mono\">\n                        {new Date(item.timestamp).toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\' })}\n                      </span>\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          )}\n        </div>\n\n        {/* Right Side: Diff & Approval Actions */}\n        <div className=\"lg:col-span-3\">\n          {selectedItem ? (\n            <div className=\"bg-white rounded-2xl border border-slate-205 p-5 flex flex-col justify-between h-full shadow-sm\">\n              <div className=\"space-y-5\">\n                {/* Header Information */}\n                <div className=\"flex justify-between items-start border-b border-slate-100 pb-3\">\n                  <div>\n                    <span className=\"text-4xs text-slate-400 font-mono block\">Action ID: {selectedItem.id}</span>\n                    <h3 className=\"text-xs font-bold text-slate-805 mt-0.5 tracking-tight font-display\">{selectedItem.details.title}</h3>\n                  </div>\n                  \n                  <div className=\"flex items-center gap-1 text-3xs font-mono text-slate-500 font-bold\">\n                    <Clock className=\"w-3.5 h-3.5 text-slate-400\" />\n                    {new Date(selectedItem.timestamp).toLocaleDateString()} at {new Date(selectedItem.timestamp).toLocaleTimeString([], {hour: \'2-digit\', minute: \'2-digit\'})}\n                  </div>\n                </div>\n\n                {/* Proposed rationale */}\n                <div className=\"space-y-2\">\n                  <span className=\"block text-4xs font-bold text-slate-400 uppercase tracking-widest leading-none flex items-center gap-1\">\n                    <AlertCircle className=\"w-3.5 h-3.5 text-indigo-505 text-indigo-600 shrink-0\" />\n                    Agent Justification & Change Summary\n                  </span>\n                  <p className=\"text-3xs text-slate-600 bg-indigo-50/20 border border-indigo-100/50 rounded-2xl p-4 leading-relaxed italic\">\n                    \"{selectedItem.details.summary}\"\n                  </p>\n                </div>\n\n                {/* Side by side visual code diff comparison */}\n                <div className=\"space-y-2\">\n                  <span className=\"block text-4xs font-bold text-slate-400 uppercase tracking-widest leading-none\">\n                    Write Action Comparison (Before vs After)\n                  </span>\n\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                    {/* Before parameters */}\n                    <div className=\"rounded-2xl border border-red-100 flex flex-col overflow-hidden bg-red-50/20\">\n                      <span className=\"block px-3 py-2 text-4xs font-bold font-mono text-red-700 border-b border-red-100 bg-red-50 leading-none\">\n                        - CURRENT VALUE (DISCARDED)\n                      </span>\n                      <div className=\"p-3 font-mono text-3xs text-red-905 leading-relaxed overflow-x-auto max-h-48 whitespace-pre-wrap\">\n                        {selectedItem.details.before || \"// Property was previously blank or holds template values\"}\n                      </div>\n                    </div>\n\n                    {/* After parameters */}\n                    <div className=\"rounded-2xl border border-emerald-100 flex flex-col overflow-hidden bg-emerald-50/20\">\n                      <span className=\"block px-3 py-2 text-4xs font-bold font-mono text-emerald-700 border-b border-emerald-100 bg-emerald-50 leading-none\">\n                        + DRAFTED REVISION (PROPOSED COMMIT)\n                      </span>\n                      <div className=\"p-3 font-mono text-3xs text-emerald-950 leading-relaxed overflow-x-auto max-h-48 whitespace-pre-wrap font-sans\">\n                        {selectedItem.details.after}\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              {/* Action Handlers */}\n              {selectedItem.status === \'PENDING\' ? (\n                <div className=\"pt-5 border-t border-slate-150 flex items-center justify-between gap-4 mt-5\">\n                  <span className=\"text-3xs text-slate-400 flex items-center gap-1.5 font-sans font-bold uppercase tracking-wider text-[8px]\">\n                    <Eye className=\"w-4 h-4 text-indigo-500\" />\n                    Review parameters before accepting\n                  </span>\n                  \n                  <div className=\"flex gap-2.5 shrink-0\">\n                    <button\n                      onClick={() => handleAction(selectedItem.id, \'REJECT\')}\n                      disabled={isLoading}\n                      className=\"px-4.5 py-2 text-xs font-bold text-red-650 text-red-650 bg-red-50 hover:bg-red-100 rounded-xl border border-red-100 shadow-xs transition cursor-pointer animate-fade-in\"\n                    >\n                      <X className=\"w-3.5 h-3.5\" />\n                      Reject Payload\n                    </button>\n                    \n                    <button\n                      onClick={() => handleAction(selectedItem.id, \'APPROVE\')}\n                      disabled={isLoading}\n                      className=\"px-4.5 py-2 text-xs font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl shadow-xs transition flex items-center gap-1 cursor-pointer animate-fade-in\"\n                    >\n                      <Check className=\"w-3.5 h-3.5\" />\n                      Approve & Execute Commit\n                    </button>\n                  </div>\n                </div>\n              ) : (\n                <div className=\"pt-4 border-t border-slate-100 mt-4 text-3xs text-slate-400 flex justify-between items-center bg-slate-50/50 p-3 rounded-xl border border-slate-150 font-mono font-bold\">\n                  <span>Authorized choice finalized on this payload.</span>\n                  <span className=\"font-bold text-slate-600 uppercase tracking-widest text-[9px]\">\n                    Result: {selectedItem.status}\n                  </span>\n                </div>\n              )}\n            </div>\n          ) : (\n            <div className=\"h-full flex flex-col items-center justify-center text-center p-12 border border-dashed border-slate-200 bg-slate-50/50 rounded-2xl max-w-sm mx-auto font-sans\">\n              <ShieldCheck className=\"w-10 h-10 text-slate-350 mb-2\" />\n              <p className=\"text-xs font-bold text-slate-700\">No action selected</p>\n              <p className=\"text-3xs text-slate-400 mt-1\">Pick an item from the left tracking column to audit.</p>\n            </div>\n          )}\n        </div>\n\n      </div>\n    </div>"
