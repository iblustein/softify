      replacement_content: "import React, { useState } from \'react\';\nimport { \n  LayoutDashboard, \n  Link2, \n  Unlink,\n  CheckCircle, \n  Cpu, \n  FileCheck, \n  Activity, \n  Database,\n  ArrowRight,\n  RefreshCw,\n  TrendingUp,\n  Coins\n} from \'lucide-react\';\nimport { DashboardStats, ShopifyStore } from \'../types\';\n\ninterface DashboardOverviewProps {\n  stats: DashboardStats;\n  store: ShopifyStore;\n  onConnect: (url: string, scopes: string[]) => void;\n  onDisconnect: () => void;\n  onReset: () => void;\n  isLoading: boolean;\n}\n\nconst ALL_AVAILABLE_SCOPES = [\n  { id: \'read_products\', label: \'Read Products (Catalog & inventory audits)\', required: true },\n  { id: \'write_products\', label: \'Write Products (Description overhauls & tag optimization)\' },\n  { id: \'read_orders\', label: \'Read Orders (Sales analytics & fulfillment triggers)\', required: true },\n  { id: \'read_customers\', label: \'Read Customers (Contextual support responses)\' },\n  { id: \'write_themes\', label: \'Write Themes (CSS layout patches & visual assets edits)\' },\n  { id: \'read_analytics\', label: \'Read Analytics (General statistics calculation)\' }\n];\n\nexport default function DashboardOverview({\n  stats,\n  store,\n  onConnect,\n  onDisconnect,\n  onReset,\n  isLoading\n}: DashboardOverviewProps) {\n  const [storeInput, setStoreInput] = useState(store.url || \"glowthread-apparel.myshopify.com\");\n  const [selectedScopes, setSelectedScopes] = useState<string[]>(\n    store.scopes.length > 0 ? store.scopes : [\'read_products\', \'read_orders\']\n  );\n  const [showConnectForm, setShowConnectForm] = useState(!store.connected);\n\n  const handleScopeToggle = (scopeId: string) => {\n    if (scopeId === \'read_products\' || scopeId === \'read_orders\') return; // mandatory for routing mockup\n    setSelectedScopes(prev => \n      prev.includes(scopeId) ? prev.filter(s => s !== scopeId) : [...prev, scopeId]\n    );\n  };\n\n  const handleConnectSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!storeInput.trim()) return;\n    onConnect(storeInput, selectedScopes);\n    setShowConnectForm(false);\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      {/* SaaS Dashboard Title & Handshake Info */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-gray-100 pb-5\">\n        <div>\n          <h1 className=\"text-2xl font-semibold text-gray-900 tracking-tight\">SaaS Central Dashboard</h1>\n          <p className=\"text-sm text-gray-500 mt-1\">\n            Monitor connected storefront indexes, supervise concurrent agent instances, and verify write approvals.\n          </p>\n        </div>\n        \n        <div className=\"flex items-center gap-2\">\n          <button\n            onClick={onReset}\n            disabled={isLoading}\n            className=\"flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition cursor-pointer\"\n          >\n            <RefreshCw className={`w-3.5 h-3.5 ${isLoading ? \'animate-spin\' : \'\'}`} />\n            Reset Prototype DB\n          </button>\n        </div>\n      </div>\n\n      {/* Connection Panel */}\n      <div className=\"bg-white rounded-xl border border-gray-150 shadow-xs overflow-hidden\">\n        <div className=\"p-5 border-b border-gray-100 bg-gray-50 flex items-center justify-between\">\n          <div className=\"flex items-center gap-3\">\n            <div className={`p-2 rounded-lg ${store.connected ? \'bg-emerald-50 text-emerald-600\' : \'bg-amber-50 text-amber-600\'}`}>\n              <LayoutDashboard className=\"w-5 h-5\" />\n            </div>\n            <div>\n              <h2 className=\"text-sm font-semibold text-gray-900 leading-none\">Shopify Store Credentials</h2>\n              <p className=\"text-xs text-gray-500 mt-1\">\n                {store.connected ? `Successfully authenticated using Managed Agents OAuth API` : \'Storefront link inactive\'}\n              </p>\n            </div>\n          </div>\n          \n          <div className=\"flex gap-2\">\n            {store.connected ? (\n              <button\n                onClick={onDisconnect}\n                className=\"flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition border border-red-100 cursor-pointer\"\n              >\n                <Unlink className=\"w-3.5 h-3.5\" />\n                Disconnect Store\n              </button>\n            ) : (\n              <button\n                onClick={() => setShowConnectForm(true)}\n                className=\"flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-600 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition border border-indigo-100 cursor-pointer\"\n              >\n                <Link2 className=\"w-3.5 h-3.5\" />\n                Initialize Handshake\n              </button>\n            )}\n          </div>\n        </div>\n\n        {/* Store Detail Metadata */}\n        {!showConnectForm && store.connected ? (\n          <div className=\"p-6 grid grid-cols-1 md:grid-cols-3 gap-6\">\n            <div className=\"space-y-3\">\n              <span className=\"text-xs font-semibold text-gray-400 uppercase tracking-wider block\">Connected Storefront</span>\n              <div className=\"flex items-center gap-2\">\n                <CheckCircle className=\"w-4 h-4 text-emerald-500 shrink-0\" />\n                <span className=\"font-medium text-gray-900 text-lg\">{store.name}</span>\n              </div>\n              <p className=\"text-xs font-mono text-gray-500\">{store.url}</p>\n            </div>\n\n            <div className=\"space-y-3\">\n              <span className=\"text-xs font-semibold text-gray-400 uppercase tracking-wider block\">Shopify Tier & Auth Settings</span>\n              <div className=\"text-sm text-gray-800 space-y-1\">\n                <div><span className=\"text-gray-400\">Merchant Plan:</span> {store.plan}</div>\n                <div><span className=\"text-gray-400\">Local Currency:</span> {store.currency}</div>\n                <div><span className=\"text-gray-400\">Authenticated:</span> {store.connectedAt ? new Date(store.connectedAt).toLocaleDateString() : \'N/A\'}</div>\n              </div>\n            </div>\n\n            <div className=\"space-y-2\">\n              <span className=\"text-xs font-semibold text-gray-400 uppercase tracking-wider block\">Authorized Scopes ({store.scopes.length})</span>\n              <div className=\"flex flex-wrap gap-1\">\n                {store.scopes.map(scope => (\n                  <span key={scope} className=\"inline-flex items-center px-2 py-0.5 text-2xs font-mono font-medium rounded-full bg-indigo-50 text-indigo-700 border border-indigo-100\">\n                    {scope}\n                  </span>\n                ))}\n              </div>\n            </div>\n          </div>\n        ) : (\n          <div className=\"p-6\">\n            <h3 className=\"text-sm font-semibold text-gray-800 mb-4\">Connect Store via Simulated OAuth</h3>\n            <form onSubmit={handleConnectSubmit} className=\"space-y-4 max-w-2xl\">\n              <div>\n                <label className=\"block text-xs font-medium text-gray-700 mb-1\">\n                  Shopify Store domain (.myshopify.com)\n                </label>\n                <div className=\"relative\">\n                  <span className=\"absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 text-sm font-mono pointer-events-none\">\n                    https://\n                  </span>\n                  <input\n                    type=\"text\"\n                    value={storeInput}\n                    onChange={(e) => setStoreInput(e.target.value)}\n                    placeholder=\"your-shop-name.myshopify.com\"\n                    className=\"w-full pl-18 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-mono\"\n                    required\n                  />\n                </div>\n                <p className=\"text-3xs text-gray-400 mt-1\">\n                  No real credentials required. Handshake simulates Shopify REST Admin credentials injection.\n                </p>\n              </div>\n\n              <div>\n                <label className=\"block text-xs font-medium text-gray-700 mb-2\">\n                  Requested Scopes (Required capabilities for Agent tool gateways)\n                </label>\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs\">\n                  {ALL_AVAILABLE_SCOPES.map(scope => {\n                    const checked = selectedScopes.includes(scope.id);\n                    return (\n                      <div \n                        key={scope.id} \n                        onClick={() => handleScopeToggle(scope.id)}\n                        className={`p-2.5 rounded-lg border flex items-start gap-2.5 cursor-pointer transition ${\n                          checked \n                            ? \'bg-indigo-25/50 border-indigo-200 text-indigo-950\' \n                            : \'bg-white border-gray-200 text-gray-600 hover:bg-gray-50\'\n                        }`}\n                      >\n                        <input\n                          type=\"checkbox\"\n                          checked={checked}\n                          onChange={() => {}} // handled by parent div\n                          disabled={scope.required}\n                          className=\"mt-0.5 rounded text-indigo-600 focus:ring-indigo-500 border-gray-300 pointer-events-none\"\n                        />\n                        <div>\n                          <p className=\"font-semibold leading-none\">{scope.id}</p>\n                          <p className=\"text-3xs text-gray-500 mt-1 leading-snug\">{scope.label}</p>\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n              </div>\n\n              <div className=\"pt-2\">\n                <button\n                  type=\"submit\"\n                  className=\"inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg shadow-xs transition duration-150 cursor-pointer\"\n                >\n                  Confirm Permissions & Establish Hook\n                  <ArrowRight className=\"w-4 h-4\" />\n                </button>\n              </div>\n            </form>\n          </div>\n        )}\n      </div>\n\n      {/* Grid statistics metrics panel */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <div className=\"p-5 bg-white border border-gray-150 rounded-xl shadow-xs\">\n          <div className=\"flex justify-between items-start\">\n            <span className=\"text-xs font-semibold uppercase tracking-wider text-gray-400\">Active Agent Workers</span>\n            <div className=\"p-1.5 bg-indigo-50 rounded-lg text-indigo-600\">\n              <Cpu className=\"w-4 h-4\" />\n            </div>\n          </div>\n          <p className=\"text-2xl font-bold text-gray-900 mt-2\">{stats.activeAgentsCount}</p>\n          <div className=\"flex items-center gap-1.5 text-xs text-gray-500 mt-1\">\n            <span className=\"inline-block w-1.5 h-1.5 rounded-full bg-emerald-500\"></span>\n            <span>All specialized instances online</span>\n          </div>\n        </div>\n\n        <div className=\"p-5 bg-white border border-gray-150 rounded-xl shadow-xs\">\n          <div className=\"flex justify-between items-start\">\n            <span className=\"text-xs font-semibold uppercase tracking-wider text-gray-400\">Approval Queue</span>\n            <div className={`p-1.5 rounded-lg ${stats.pendingApprovalsCount > 0 ? \'bg-amber-50 text-amber-600\' : \'bg-gray-50 text-gray-400\'}`}>\n              <FileCheck className=\"w-4 h-4\" />\n            </div>\n          </div>\n          <p className=\"text-2xl font-bold text-gray-900 mt-2\">{stats.pendingApprovalsCount}</p>\n          <div className=\"flex items-center gap-1.5 text-xs text-gray-500 mt-1\">\n            <span className={stats.pendingApprovalsCount > 0 ? \'text-amber-600 font-semibold\' : \'text-gray-400\'}>\n              {stats.pendingApprovalsCount > 0 ? \'Requires shop owner review\' : \'Security buffer is empty\'}\n            </span>\n          </div>\n        </div>\n\n        <div className=\"p-5 bg-white border border-gray-150 rounded-xl shadow-xs\">\n          <div className=\"flex justify-between items-start\">\n            <span className=\"text-xs font-semibold uppercase tracking-wider text-gray-400\">Catalog Database</span>\n            <div className=\"p-1.5 bg-blue-50 rounded-lg text-blue-600\">\n              <Database className=\"w-4 h-4\" />\n            </div>\n          </div>\n          <p className=\"text-2xl font-bold text-gray-900 mt-2\">{stats.totalProductsCount}</p>\n          <div className=\"flex items-center gap-1.5 text-xs text-gray-500 mt-1 flex-wrap\">\n            <span>5 structured sandbox listings ready</span>\n          </div>\n        </div>\n\n        <div className=\"p-5 bg-white border border-gray-150 rounded-xl shadow-xs\">\n          <div className=\"flex justify-between items-start\">\n            <span className=\"text-xs font-semibold uppercase tracking-wider text-gray-400\">Audit Actions</span>\n            <div className=\"p-1.5 bg-violet-50 rounded-lg text-violet-600\">\n              <Activity className=\"w-4 h-4\" />\n            </div>\n          </div>\n          <p className=\"text-2xl font-bold text-gray-900 mt-2\">{stats.totalLogsCount}</p>\n          <div className=\"flex items-center gap-1.5 text-xs text-emerald-600 mt-1\">\n            <TrendingUp className=\"w-3.5 h-3.5\" />\n            <span>100% telemetry coverage</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Split pane for mini summaries */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        {/* Sandbox Store Mock Database Insight card */}\n        <div className=\"lg:col-span-2 bg-white rounded-xl border border-gray-150 p-5 space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-gray-100 pb-3\">\n            <h3 className=\"text-sm font-semibold text-gray-900 flex items-center gap-2\">\n              <Database className=\"w-4 h-4 text-indigo-500\" />\n              Connected Shopify Sandbox\n            </h3>\n            <span className=\"text-xs text-gray-400\">Sync status: Live Mock</span>\n          </div>\n\n          {!store.connected ? (\n            <div className=\"py-10 text-center text-gray-500 max-w-sm mx-auto\">\n              <Unlink className=\"w-8 h-8 mx-auto text-gray-300 mb-2\" />\n              <p className=\"text-sm font-medium\">Shopify Connection offline</p>\n              <p className=\"text-xs text-gray-400 mt-1\">Please connect your store or use the sample config to run queries.</p>\n            </div>\n          ) : (\n            <div className=\"space-y-4\">\n              <div className=\"grid grid-cols-3 gap-3 bg-gray-50 p-4 rounded-xl text-center\">\n                <div>\n                  <span className=\"text-2xs text-gray-400 uppercase tracking-widest block font-medium\">Conversion Rate</span>\n                  <span className=\"text-base font-bold text-gray-900 mt-1 block\">{mockSalesReport.conversionRate}</span>\n                </div>\n                <div>\n                  <span className=\"text-2xs text-gray-400 uppercase tracking-widest block font-medium\">Est. Weekly Revenue</span>\n                  <span className=\"text-base font-bold text-indigo-600 mt-1 block\">${mockSalesReport.totalWeekRevenue}</span>\n                </div>\n                <div>\n                  <span className=\"text-2xs text-gray-400 uppercase tracking-widest block font-medium\">Active Web Sessions</span>\n                  <span className=\"text-base font-bold text-gray-900 mt-1 block\">{mockSalesReport.activeSessions}</span>\n                </div>\n              </div>\n\n              <div>\n                <h4 className=\"text-xs font-semibold text-gray-700 uppercase tracking-wider mb-2\">High performance SKU metrics</h4>\n                <div className=\"space-y-2\">\n                  {mockSalesReport.popularProducts.map((p, i) => (\n                    <div key={i} className=\"flex justify-between items-center p-2.5 bg-gray-25 hover:bg-gray-50 rounded-lg border border-gray-100 text-xs transition\">\n                      <div className=\"font-semibold text-gray-900\">{p.name}</div>\n                      <div className=\"flex items-center gap-4 text-gray-500 font-mono\">\n                        <div>Sales: <span className=\"font-semibold text-gray-800\">{p.salesCount}</span></div>\n                        <div>Revenue: <span className=\"font-semibold text-emerald-600\">${p.revenue}</span></div>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n\n        {/* Guided Overview panel */}\n        <div className=\"bg-indigo-950 text-white rounded-xl p-5 flex flex-col justify-between shadow-xs\">\n          <div className=\"space-y-4\">\n            <span className=\"inline-flex items-center px-2 py-0.5 rounded-full text-2xs font-semibold bg-indigo-900 text-indigo-200 border border-indigo-800\">\n              Agent Registry V1.2\n            </span>\n            <h3 className=\"text-base font-bold text-white tracking-tight leading-snug\">\n              Gemini Managed Agents Paradigm\n            </h3>\n            <p className=\"text-xs text-indigo-200 leading-relaxed\">\n              Based on the newest Gemini architecture, the **Super Agent Orchestrator** reads store instructions, routes queries to specialized units, and schedules safe parameters actions through a central **Tool Gateway**.\n            </p>\n            <div className=\"space-y-2 pt-2\">\n              <div className=\"flex items-center gap-2 text-xs text-indigo-100\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400\"></span>\n                <span>Sandbox databases operate on stateful mocks</span>\n              </div>\n              <div className=\"flex items-center gap-2 text-xs text-indigo-100\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-blue-400\"></span>\n                <span>Real-time safety approval queue gates</span>\n              </div>\n              <div className=\"flex items-center gap-2 text-xs text-indigo-100\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-indigo-400\"></span>\n                <span>Full metadata logging for live audits</span>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"pt-4 border-t border-indigo-900 mt-4 flex items-center justify-between text-2xs text-indigo-300\">\n            <span>Shopify OAuth Hook Layer Ready</span>\n            <Coins className=\"w-4 h-4 text-indigo-400\" />\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
