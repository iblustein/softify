  file_change {
    absolute_path_uri: "file:///src/components/SuperAgentUI.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useRef, useEffect } from \'react\';\nimport { \n  Cpu, \n  Send, \n  Bot, \n  User, \n  Layers, \n  Activity, \n  ChevronRight, \n  Play, \n  FileCheck,\n  Sparkles,\n  RefreshCw,\n  Clock,\n  ExternalLink\n} from \'lucide-react\';\nimport { Agent, OrchestrationMessage } from \'../types\';\n\ninterface SuperAgentUIProps {\n  agents: Agent[];\n  messages: OrchestrationMessage[];\n  onSendMessage: (prompt: string, bypassAgentId?: string) => void;\n  isLoading: boolean;\n  onNavigateToApprovals: () => void;\n}\n\nconst SAMPLE_COMMANDS = [\n  {\n    title: \"Optimize Product Descriptions\",\n    prompt: \"Write a high-converting optimized description for the Eco Linen Warm Shirt and draft it as a product update.\",\n    agentId: \"agent_content\",\n    desc: \"Content Agent \342\200\242 Generates description rewrite & files to approvals\"\n  },\n  {\n    title: \"Check Store Analytics\",\n    prompt: \"Analyze the total week sales revenue metrics and conversion trends.\",\n    agentId: \"agent_analytics\",\n    desc: \"Analytics Agent \342\200\242 Queries sales summaries and lists highest performers\"\n  },\n  {\n    title: \"Change Theme Layout CSS\",\n    prompt: \"Optimize the Shopify theme primary buttons styling with responsive padding offsets.\",\n    agentId: \"agent_theme_dev\",\n    desc: \"Theme Dev Agent \342\200\242 Submits responsive CSS patch overrides\"\n  },\n  {\n    title: \"Audit Customer Histories\",\n    prompt: \"Check recent orders and customer queries.\",\n    agentId: \"agent_customer_support\",\n    desc: \"Customer Support Agent \342\200\242 Retries orders and support histories\"\n  }\n];\n\nexport default function SuperAgentUI({\n  agents,\n  messages,\n  onSendMessage,\n  isLoading,\n  onNavigateToApprovals\n}: SuperAgentUIProps) {\n  const [inputText, setInputText] = useState(\"\");\n  const [bypassAgentId, setBypassAgentId] = useState(\"\");\n  const chatBottomRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    chatBottomRef.current?.scrollIntoView({ behavior: \'smooth\' });\n  }, [messages, isLoading]);\n\n  const handleSend = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!inputText.trim() || isLoading) return;\n    onSendMessage(inputText.trim(), bypassAgentId ? bypassAgentId : undefined);\n    setInputText(\"\");\n  };\n\n  const handleSampleClick = (prompt: string, agentId: string) => {\n    if (isLoading) return;\n    setBypassAgentId(agentId);\n    onSendMessage(prompt, agentId);\n  };\n\n  return (\n    <div className=\"grid grid-cols-1 xl:grid-cols-4 gap-6 items-start h-[calc(100vh-14rem)] min-h-[500px]\">\n      {/* Central Chat Screen */}\n      <div className=\"xl:col-span-3 flex flex-col bg-white border border-gray-150 rounded-xl h-full shadow-xs\">\n        {/* Terminal Header */}\n        <div className=\"p-4 border-b border-gray-150 flex items-center justify-between bg-gray-50/50\">\n          <div className=\"flex items-center gap-2\">\n            <div className=\"w-2.5 h-2.5 rounded-full bg-indigo-500 animate-pulse shrink-0\"></div>\n            <div>\n              <h3 className=\"text-xs font-bold text-gray-900\">Super Agent Orchestration Terminal</h3>\n              <p className=\"text-4xs text-gray-500 mt-0.5 uppercase tracking-widest font-mono\">Gemini-Managed Routing Active</p>\n            </div>\n          </div>\n          \n          <div className=\"flex items-center gap-1.5 bg-indigo-50 border border-indigo-100 text-indigo-700 px-2 py-0.5 rounded text-4xs font-mono\">\n            <Sparkles className=\"w-3 h-3 text-indigo-500\" />\n            AI Router Mode: {bypassAgentId ? \"Locked\" : \"Automatic Dynamic\"}\n          </div>\n        </div>\n\n        {/* Message Feeds */}\n        <div className=\"flex-1 overflow-y-auto p-5 space-y-4\">\n          {messages.length === 0 ? (\n            <div className=\"h-full flex flex-col items-center justify-center text-center max-w-sm mx-auto p-5\">\n              <Bot className=\"w-12 h-12 text-indigo-200 mb-3\" />\n              <h4 className=\"text-sm font-semibold text-gray-900\">Control center initialization completed</h4>\n              <p className=\"text-xs text-gray-500 mt-1 leading-relaxed\">\n                Enter an instruction to test orchestrator routing logic. Select a sample task below or type custom Shopify requests.\n              </p>\n            </div>\n          ) : (\n            messages.map((msg, index) => {\n              const isOrchestrator = msg.sender === \'orchestrator\';\n              const isUser = msg.sender === \'user\';\n              const isAgent = msg.sender === \'agent\';\n\n              return (\n                <div \n                  key={msg.id || index}\n                  className={`flex items-start gap-4 ${isUser ? \'justify-end\' : \'justify-start\'}`}\n                >\n                  {/* Sender icons */}\n                  {!isUser && (\n                    <div className={`w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs shrink-0 ${\n                      isOrchestrator ? \'bg-indigo-950 text-indigo-200 border border-indigo-800\' : \'bg-indigo-600 text-white\'\n                    }`}>\n                      {isOrchestrator ? <Layers className=\"w-4 h-4\" /> : <Bot className=\"w-4 h-4\" />}\n                    </div>\n                  )}\n\n                  <div className={`max-w-xl rounded-xl p-4 text-xs leading-relaxed border ${\n                    isUser \n                      ? \'bg-indigo-600 text-white border-indigo-700\' \n                      : isOrchestrator \n                      ? \'bg-gray-50 text-gray-700 border-gray-150\' \n                      : \'bg-white text-gray-800 border-gray-150 shadow-2xs\'\n                  }`}>\n                    {/* Header line for non-user posts */}\n                    {!isUser && (\n                      <div className=\"flex items-center justify-between border-b border-gray-100/50 pb-1.5 mb-2 text-2xs font-semibold\">\n                        <span className={isOrchestrator ? \'text-indigo-950\' : \'text-indigo-600\'}>\n                          {isOrchestrator ? \'Super Agent Router\' : msg.agentName || \'Agent Worker\'}\n                        </span>\n                        <span className=\"text-4xs text-gray-400 font-normal flex items-center gap-1\">\n                          <Clock className=\"w-3 h-3\" />\n                          {new Date(msg.timestamp).toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\', second: \'2-digit\' })}\n                        </span>\n                      </div>\n                    )}\n\n                    {/* Chat Text */}\n                    <div className=\"prose prose-xs whitespace-pre-line text-xs font-sans leading-relaxed\">\n                      {msg.text}\n                    </div>\n\n                    {/* Tool executions indicators */}\n                    {msg.toolInvocations && msg.toolInvocations.length > 0 && (\n                      <div className=\"border-t border-gray-100 pt-3 mt-3 space-y-2\">\n                        <span className=\"block text-4xs font-semibold text-gray-400 uppercase tracking-widest leading-none\">\n                          Tool Gateway Pipeline Execution\n                        </span>\n                        \n                        <div className=\"space-y-1.5\">\n                          {msg.toolInvocations.map((tool, tIdx) => (\n                            <div key={tIdx} className=\"bg-gray-50 border border-gray-100 rounded p-2 flex flex-col gap-1.5\">\n                              <div className=\"flex items-center justify-between text-3xs font-mono\">\n                                <span className=\"font-semibold text-gray-800 flex items-center gap-1\">\n                                  <Activity className=\"w-3 h-3 text-indigo-500\" />\n                                  {tool.toolName}\n                                </span>\n                                <span className={`px-1 rounded-sm text-4xs ${\n                                  tool.status === \'success\' \n                                    ? \'bg-emerald-50 text-emerald-700 border border-emerald-100\' \n                                    : \'bg-amber-50 text-amber-700 border border-amber-100\'\n                                }`}>\n                                  {tool.status === \'success\' ? \'READ_SUCCESS\' : \'AWAITING_OWNER_HANDSHAKE\'}\n                                </span>\n                              </div>\n                              \n                              <div className=\"text-4xs text-gray-400 font-mono\">\n                                Args: <span className=\"text-gray-500\">{JSON.stringify(tool.args)}</span>\n                              </div>\n\n                              {tool.approvalId && (\n                                <div className=\"mt-1 flex items-center justify-between bg-amber-50/50 border border-amber-100 rounded p-1 text-3xs text-amber-900 leading-snug\">\n                                  <span>Action locked inside approval index: <strong>{tool.approvalId}</strong></span>\n                                  <button \n                                    onClick={onNavigateToApprovals}\n                                    className=\"flex items-center gap-0.5 px-1.5 py-0.5 bg-amber-600 hover:bg-amber-700 text-white rounded font-semibold text-4xs leading-none transition cursor-pointer\"\n                                  >\n                                    Approve Change\n                                    <ChevronRight className=\"w-2.5 h-2.5\" />\n                                  </button>\n                                </div>\n                              )}\n                            </div>\n                          ))}\n                        </div>\n                      </div>\n                    )}\n                  </div>\n\n                  {isUser && (\n                    <div className=\"w-8 h-8 rounded-lg flex items-center justify-center bg-gray-200 text-gray-600 font-bold text-xs shrink-0 select-none border border-gray-300\">\n                      <User className=\"w-4 h-4\" />\n                    </div>\n                  )}\n                </div>\n              );\n            })\n          )}\n\n          {isLoading && (\n            <div className=\"flex items-start gap-4\">\n              <div className=\"w-8 h-8 rounded-lg flex items-center justify-center bg-indigo-950 text-indigo-200 border border-indigo-800 shrink-0\">\n                <RefreshCw className=\"w-4 h-4 animate-spin\" />\n              </div>\n              <div className=\"bg-gray-50 border border-gray-150 text-gray-500 rounded-xl p-4 text-xs flex items-center gap-2 max-w-sm\">\n                <div className=\"flex gap-1\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce\" style={{ animationDelay: \'0ms\' }}></span>\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce\" style={{ animationDelay: \'150ms\' }}></span>\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce\" style={{ animationDelay: \'300ms\' }}></span>\n                </div>\n                <span>Super Agent processing prompts...</span>\n              </div>\n            </div>\n          )}\n\n          <div ref={chatBottomRef} />\n        </div>\n\n        {/* Input Panel */}\n        <form onSubmit={handleSend} className=\"p-4 border-t border-gray-150 bg-gray-50/50 flex flex-col md:flex-row gap-3 items-stretch\">\n          <div className=\"flex-1 relative flex items-center\">\n            <input\n              type=\"text\"\n              value={inputText}\n              onChange={(e) => setInputText(e.target.value)}\n              disabled={isLoading}\n              placeholder=\"e.g. Write a description update for Walnut headphone stand...\"\n              className=\"w-full pl-3 pr-24 py-2.5 text-xs border border-gray-350 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-sans shadow-xs\"\n              required\n            />\n            \n            {/* Direct Bypass Picker */}\n            <div className=\"absolute right-2 top-1.5\">\n              <select\n                value={bypassAgentId}\n                onChange={(e) => setBypassAgentId(e.target.value)}\n                disabled={isLoading}\n                className=\"text-4xs font-mono font-semibold bg-gray-100 border border-gray-200 text-gray-600 rounded px-1.5 py-1 focus:outline-none\"\n              >\n                <option value=\"\">Auto Route</option>\n                {agents.map(a => (\n                  <option key={a.id} value={a.id}>{a.name.split(\' \')[0]}</option>\n                ))}\n              </select>\n            </div>\n          </div>\n\n          <button\n            type=\"submit\"\n            disabled={isLoading || !inputText.trim()}\n            className=\"px-4 py-2 text-xs font-semibold text-white bg-indigo-600 hover:bg-indigo-700 disabled:bg-gray-300 rounded-lg flex items-center justify-center gap-1.5 transition cursor-pointer\"\n          >\n            Send Command\n            <Send className=\"w-3.5 h-3.5\" />\n          </button>\n        </form>\n      </div>\n\n      {/* Side Quick Prompt Panel */}\n      <div className=\"space-y-4\">\n        <div className=\"bg-white border border-gray-150 rounded-xl p-4 shadow-xs\">\n          <h3 className=\"text-xs font-bold text-gray-900 uppercase tracking-wide border-b border-gray-100 pb-2 mb-3\">\n            Quick Start Scenarios\n          </h3>\n          \n          <div className=\"space-y-2.5\">\n            {SAMPLE_COMMANDS.map((cmd, i) => (\n              <div \n                key={i}\n                onClick={() => handleSampleClick(cmd.prompt, cmd.agentId)}\n                className=\"group p-3 rounded-lg border border-gray-100 bg-gray-25 hover:bg-indigo-25/30 hover:border-indigo-200 transition text-xs cursor-pointer flex flex-col gap-1\"\n              >\n                <div className=\"flex justify-between items-center text-3xs font-semibold text-gray-800 group-hover:text-indigo-950\">\n                  <span>{cmd.title}</span>\n                  <Play className=\"w-2.5 h-2.5 text-gray-400 group-hover:text-indigo-600 group-hover:translate-x-0.5 transition\" />\n                </div>\n                <p className=\"text-3xs text-gray-500 line-clamp-2 leading-relaxed italic\">\n                  \"{cmd.prompt}\"\n                </p>\n                <p className=\"text-4xs font-mono text-gray-400 mt-0.5 uppercase tracking-wider\">\n                  {cmd.desc}\n                </p>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Real-time agent status tracker widget */}\n        <div className=\"bg-white border border-gray-150 rounded-xl p-4 shadow-xs\">\n          <h3 className=\"text-xs font-bold text-gray-900 uppercase tracking-wide border-b border-gray-100 pb-2 mb-2.5\">\n            Agent Registry Monitor\n          </h3>\n          \n          <div className=\"space-y-2\">\n            {agents.map(agent => (\n              <div key={agent.id} className=\"flex justify-between items-center text-3xs\">\n                <span className=\"font-semibold text-gray-700\">{agent.name}</span>\n                <span className={`inline-flex items-center gap-1.5 ${\n                  agent.enabled ? \'text-emerald-600 font-bold\' : \'text-gray-400\'\n                }`}>\n                  <span className={`w-1 h-1 rounded-full ${\n                    agent.enabled ? \'bg-emerald-500\' : \'bg-gray-300\'\n                  }`}></span>\n                  {agent.enabled ? \'STANDBY\' : \'OFFLINE\'}\n                </span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
