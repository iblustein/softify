      replacement_content: "import React, { useState } from \'react\';\nimport { \n  Users, \n  Settings, \n  ShieldCheck, \n  ShieldAlert, \n  Cpu, \n  ToggleLeft, \n  ToggleRight, \n  ListTodo,\n  AlertCircle\n} from \'lucide-react\';\nimport { Agent, RiskLevel } from \'../types\';\n\ninterface AgentRegistryProps {\n  agents: Agent[];\n  onUpdateAgent: (id: string, updates: Partial<Agent>) => void;\n  isLoading: boolean;\n}\n\nconst RISK_BADGES: Record<RiskLevel, { text: string; bg: string; textCol: string; ring: string }> = {\n  Low: { text: \"Low Risk\", bg: \"bg-emerald-50\", textCol: \"text-emerald-700\", ring: \"ring-emerald-600/10\" },\n  Medium: { text: \"Medium Risk\", bg: \"bg-amber-50\", textCol: \"text-amber-700\", ring: \"ring-amber-600/10\" },\n  High: { text: \"High Risk \342\200\224 Direct Gateway\", bg: \"bg-red-50\", textCol: \"text-red-700\", ring: \"ring-red-600/10\" }\n};\n\nconst PROTOCOLS_LIST = [\n  \"shopify.getShopInfo\",\n  \"shopify.getProducts\",\n  \"shopify.getOrders\",\n  \"shopify.getSalesSummary\",\n  \"shopify.prepareProductUpdate\",\n  \"shopify.prepareThemePatch\"\n];\n\nexport default function AgentRegistry({\n  agents,\n  onUpdateAgent,\n  isLoading\n}: AgentRegistryProps) {\n  const [selectedAgent, setSelectedAgent] = useState<Agent | null>(agents[0] || null);\n  const [editingInstruction, setEditingInstruction] = useState(selectedAgent?.systemInstruction || \"\");\n  const [editingTools, setEditingTools] = useState<string[]>(selectedAgent?.allowedTools || []);\n\n  const handleAgentClick = (agent: Agent) => {\n    setSelectedAgent(agent);\n    setEditingInstruction(agent.systemInstruction);\n    setEditingTools(agent.allowedTools);\n  };\n\n  const handleToggle = (agent: Agent) => {\n    onUpdateAgent(agent.id, { enabled: !agent.enabled });\n    if (selectedAgent && selectedAgent.id === agent.id) {\n      setSelectedAgent(prev => prev ? { ...prev, enabled: !prev.enabled } : null);\n    }\n  };\n\n  const handleToolCheck = (tool: string) => {\n    setEditingTools(prev => \n      prev.includes(tool) \n        ? prev.filter(t => t !== tool) \n        : [...prev, tool]\n    );\n  };\n\n  const handleSaveConfigs = () => {\n    if (!selectedAgent) return;\n    onUpdateAgent(selectedAgent.id, {\n      systemInstruction: editingInstruction,\n      allowedTools: editingTools\n    });\n\n    // alert configuration saved locally for UI feedback\n    const original = agents.find(a => a.id === selectedAgent.id);\n    if (original) {\n      setSelectedAgent({\n        ...selectedAgent,\n        systemInstruction: editingInstruction,\n        allowedTools: editingTools\n      });\n    }\n  };\n\n  return (\n    <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 h-full items-start\">\n      {/* List section */}\n      <div className=\"lg:col-span-2 space-y-4\">\n        <div className=\"flex justify-between items-center border-b border-gray-100 pb-3\">\n          <div className=\"flex items-center gap-2\">\n            <Users className=\"w-5 h-5 text-indigo-600\" />\n            <h2 className=\"text-sm font-semibold text-gray-900 leading-none\">Managed Agent Registry</h2>\n          </div>\n          <span className=\"text-2xs font-mono px-2 py-0.5 roundedbg bg-indigo-50 border border-indigo-100 text-indigo-600\">\n            {agents.length} Models Instantiated\n          </span>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n          {agents.map((agent) => {\n            const isSelected = selectedAgent?.id === agent.id;\n            return (\n              <div \n                key={agent.id}\n                onClick={() => handleAgentClick(agent)}\n                className={`p-4 rounded-xl border transition-all cursor-pointer flex flex-col justify-between h-42 ${\n                  isSelected \n                    ? \'bg-indigo-25/40 border-indigo-400 ring-2 ring-indigo-400/10\' \n                    : \'bg-white border-gray-150 hover:border-gray-300\'\n                }`}\n              >\n                <div>\n                  <div className=\"flex justify-between items-start\">\n                    <div className=\"flex items-center gap-2.5\">\n                      <div className={`w-8 h-8 rounded-lg ${agent.avatarColor} flex items-center justify-center font-bold text-xs shrink-0`}>\n                        {agent.name.split(\' \').map(n=>n[0]).join(\'\')}\n                      </div>\n                      <div>\n                        <h3 className=\"text-xs font-bold text-gray-900\">{agent.name}</h3>\n                        <span className={`inline-flex items-center text-3xs font-medium px-1.5 py-0.5 mt-1 rounded-sm ring-1 ring-inset ${\n                          RISK_BADGES[agent.riskLevel].bg\n                        } ${RISK_BADGES[agent.riskLevel].textCol} ${RISK_BADGES[agent.riskLevel].ring}`}>\n                          {RISK_BADGES[agent.riskLevel].text}\n                        </span>\n                      </div>\n                    </div>\n\n                    <button\n                      onClick={(e) => {\n                        e.stopPropagation();\n                        handleToggle(agent);\n                      }}\n                      className=\"text-gray-400 hover:text-gray-600 transition\"\n                    >\n                      {agent.enabled ? (\n                        <ToggleRight className=\"w-6 h-6 text-indigo-600\" />\n                      ) : (\n                        <ToggleLeft className=\"w-6 h-6 text-gray-300\" />\n                      )}\n                    </button>\n                  </div>\n\n                  <p className=\"text-3xs text-gray-500 mt-3 line-clamp-2 leading-relaxed\">\n                    {agent.systemInstruction}\n                  </p>\n                </div>\n\n                <div className=\"flex justify-between items-center border-t border-gray-50 pt-2.5 mt-2.5 text-3xs text-gray-400\">\n                  <span className=\"font-mono\">Scopes: {agent.requiredScopes.length}</span>\n                  <span className=\"font-mono\">{agent.allowedTools.length} tools allowed</span>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n\n      {/* Editor Sidebar Pane */}\n      <div className=\"bg-white rounded-xl border border-gray-150 p-5 space-y-5\">\n        <div className=\"flex items-center gap-2 border-b border-gray-100 pb-3\">\n          <Settings className=\"w-4 h-4 text-gray-500\" />\n          <h3 className=\"text-xs font-bold text-gray-900 uppercase tracking-wide\">Configure Agent Parameters</h3>\n        </div>\n\n        {selectedAgent ? (\n          <div className=\"space-y-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className={`w-10 h-10 rounded-xl ${selectedAgent.avatarColor} flex items-center justify-center font-bold text-sm shrink-0`}>\n                {selectedAgent.name.split(\' \').map(n=>n[0]).join(\'\')}\n              </div>\n              <div>\n                <h4 className=\"font-bold text-sm text-gray-900\">{selectedAgent.name}</h4>\n                <div className=\"flex items-center gap-2 mt-0.5\">\n                  <span className={`inline-flex items-center px-1.5 py-0.5 rounded text-3xs font-medium ${\n                    selectedAgent.enabled ? \'bg-emerald-50 text-emerald-700\' : \'bg-gray-50 text-gray-500\'\n                  }`}>\n                    {selectedAgent.enabled ? \'Active Workers Enabled\' : \'Disabled\'}\n                  </span>\n                  <span className=\"text-3xs text-gray-400\">\342\200\242</span>\n                  <span className=\"text-3xs font-mono text-gray-500\">{selectedAgent.id}</span>\n                </div>\n              </div>\n            </div>\n\n            {/* Instruction editor */}\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between items-center\">\n                <label className=\"block text-3xs font-semibold text-gray-400 uppercase tracking-wider\">\n                  System Instruction Prompt\n                </label>\n                <span className=\"text-3xs text-gray-400 font-mono\">Tuning Window</span>\n              </div>\n              <textarea\n                value={editingInstruction}\n                onChange={(e) => setEditingInstruction(e.target.value)}\n                className=\"w-full h-32 px-3  py-2 text-xs border border-gray-200 rounded-lg text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 font-sans leading-relaxed\"\n                placeholder=\"Declare precise behavioral constraints for this agent...\"\n              />\n              <p className=\"text-3xs text-gray-400 leading-none\">\n                Injected of system prompting parameters during orchestrations.\n              </p>\n            </div>\n\n            {/* Scopes & tools editor */}\n            <div className=\"space-y-3\">\n              <div>\n                <span className=\"block text-3xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5\">\n                  Required Shopify OAuth Scopes (Immutable)\n                </span>\n                <div className=\"flex flex-wrap gap-1\">\n                  {selectedAgent.requiredScopes.map(scope => (\n                    <span key={scope} className=\"px-1.5 py-0.5 text-3xs font-mono rounded bg-gray-50 border border-gray-150 text-gray-600\">\n                      {scope}\n                    </span>\n                  ))}\n                </div>\n              </div>\n\n              <div>\n                <span className=\"block text-3xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5\">\n                  Delegated Gateway Tools\n                </span>\n                <div className=\"space-y-1.5 max-h-40 overflow-y-auto border border-gray-100 rounded-lg p-2.5 bg-gray-25\">\n                  {PROTOCOLS_LIST.map((tool) => {\n                    const isAllowed = editingTools.includes(tool);\n                    return (\n                      <div \n                        key={tool}\n                        onClick={() => handleToolCheck(tool)}\n                        className={`flex items-center justify-between p-1.5 rounded text-3xs cursor-pointer transition ${\n                          isAllowed ? \'bg-indigo-50/50 text-indigo-900 font-semibold\' : \'text-gray-500 hover:bg-gray-50\'\n                        }`}\n                      >\n                        <span className=\"font-mono\">{tool}</span>\n                        <input\n                          type=\"checkbox\"\n                          checked={isAllowed}\n                          onChange={() => {}} // handled by click\n                          className=\"rounded text-indigo-600 focus:ring-indigo-500 border-gray-300 pointer-events-none\"\n                        />\n                      </div>\n                    );\n                  })}\n                </div>\n              </div>\n            </div>\n\n            {/* Save Buttons */}\n            <div className=\"pt-3 border-t border-gray-100 flex items-center justify-between gap-2\">\n              <span className=\"text-3xs text-gray-400 flex items-center gap-1 leading-none\">\n                <AlertCircle className=\"w-3.5 h-3.5 text-indigo-500 shrink-0\" />\n                Live tuning updates\n              </span>\n              <button\n                onClick={handleSaveConfigs}\n                disabled={isLoading}\n                className=\"px-4 py-2 text-xs font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg shadow-2xs transition cursor-pointer\"\n              >\n                Apply Parameters\n              </button>\n            </div>\n          </div>\n        ) : (\n          <div className=\"py-20 text-center text-gray-400 text-xs\">\n            <Cpu className=\"w-8 h-8 mx-auto text-gray-200 mb-2\" />\n            Pick an agent from the registry to review configurations.\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n"
    }
