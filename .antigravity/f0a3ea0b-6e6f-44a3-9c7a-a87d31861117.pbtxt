ext-indigo-700 border border-indigo-100\'\n                    }`}>\n                      {isWrite ? \'WRITE\' : \'READ_ONLY\'}\n                    </span>\n                  </div>\n                  <p className=\"text-3xs text-gray-500 mt-1.5 line-clamp-1 leading-snug\">\n                    {tool.description}\n                  </p>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* Right Side: Tool Details & Sandbox Console */}\n        <div className=\"lg:col-span-3 grid grid-cols-1 md:grid-cols-2 gap-4 items-stretch\">\n          \n          {/* Detailed parameters Card */}\n          <div className=\"bg-white border border-gray-150 rounded-xl p-4 flex flex-col justify-between shadow-2xs\">\n            <div className=\"space-y-4\">\n              <div className=\"border-b border-gray-100 pb-2 flex justify-between items-start\">\n                <div>\n                  <h3 className=\"text-xs font-bold text-gray-900 font-mono\">{selectedTool.name}</h3>\n                  <span className=\"text-4xs text-gray-400 block font-mono mt-0.5\">{selectedTool.endpoints}</span>\n                </div>\n                \n                <div className=\"flex items-center gap-1 bg-red-50 border border-red-100 px-1.5 py-0.5 rounded text-4xs text-red-700 font-mono\">\n                  <Lock className=\"w-2.5 h-2.5\" />\n                  Scope: {selectedTool.scope.split(\', \')[0]}\n                </div>\n              </div>\n\n              <div className=\"space-y-2\">\n                <span className=\"block text-4xs font-semibold text-gray-400 uppercase tracking-widest leading-none\">\n                  Description\n                </span>\n                <p className=\"text-3xs text-gray-600 leading-relaxed italic\">\n                  \"{selectedTool.description}\"\n                </p>\n              </div>\n\n              {selectedTool.parameters.length > 0 ? (\n                <div className=\"space-y-2\">\n                  <span className=\"block text-4xs font-semibold text-gray-400 uppercase tracking-widest leading-none\">\n                    Required Arguments\n                  </span>\n                  \n                  <div className=\"space-y-2 border border-gray-100 bg-gray-25 rounded-lg p-2.5 max-h-40 overflow-y-auto\">\n                    {selectedTool.parameters.map((param) => (\n                      <div key={param.name} className=\"flex justify-between items-start text-3xs border-b border-gray-100 last:border-b-0 pb-1.5 last:pb-0\">\n                        <div>\n                          <span className=\"font-semibold text-gray-900 font-mono\">{param.name}</span>\n                          <span className=\"text-4xs text-gray-400 font-mono ml-1.5\">{param.type}</span>\n                          <p className=\"text-gray-500 mt-0.5\">{param.desc}</p>\n                        </div>\n                        {param.required && (\n                          <span className=\"px-1 py-0.5 rounded bg-red-50 text-red-700 text-[8px] font-semibold border border-red-100\">\n                            Required\n                          </span>\n                        )}\n                      </div>\n                    ))}\n                  </div>\n                </div>\n              ) : (\n                <div className=\"p-3 border border-dashed border-gray-150 rounded-lg text-center text-4xs text-gray-400\">\n                  <Info className=\"w-3.5 h-3.5 mx-auto text-gray-300 mb-1\" />\n                  No arguments required. Executed using global connected store session keys.\n                </div>\n              )}\n            </div>\n\n            <div className=\"pt-3 border-t border-gray-100 flex items-center justify-between text-2xs\">\n              <span className=\"text-gray-400 flex items-center gap-1 font-mono\">\n                OAuth verification passed\n              </span>\n              <button\n                onClick={handleExecuteMock}\n                disabled={isConsoleRunning || isLoading}\n                className=\"inline-flex items-center gap-1 px-3 py-1.5 font-semibold text-white bg-indigo-600 hover:bg-indigo-700 disabled:bg-indigo-300 rounded-lg shadow-2xs transition text-4xs cursor-pointer\"\n              >\n                {isConsoleRunning ? (\n                  <RefreshCw className=\"w-3 h-3 animate-spin\" />\n                ) : (\n                  <Play className=\"w-3 h-3\" />\n                )}\n                Execute Mock Run\n              </button>\n            </div>\n          </div>\n\n          {/* Execution Terminal display */}\n          <div className=\"bg-gray-900 rounded-xl border border-gray-800 p-4 flex flex-col h-full text-xs font-mono shadow-xs overflow-hidden\">\n            <div className=\"flex items-center justify-between border-b border-gray-800 pb-2 mb-2 text-2xs text-gray-400\">\n              <span className=\"flex items-center gap-1\">\n                <FileCode className=\"w-3.5 h-3.5 text-indigo-400\" />\n                JSON Output Terminal\n              </span>\n              <span className=\"text-3xs text-emerald-400 bg-emerald-950/40 border border-emerald-900/40 px-1.5 py-0.5 rounded\">\n                SIM_SHELL\n              </span>\n            </div>\n\n            <div className=\"flex-1 overflow-auto text-[10px] leading-relaxed text-gray-200 bg-gray-950 p-2.5 rounded-lg border border-gray-855 min-h-48\">\n              <pre className=\"whitespace-pre-wrap\">{consoleOutput}</pre>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </div>"
